	<bone-default name="first">
		<restitution>1</restitution>
	</bone-default>
	
	<bone name="CB 01 1" template="first"/>
	<bone name="CB 02 1" template="first"/>
	<bone name="CB 03 1" template="first"/>
	
	<bone name="NPC R ForearmA [RLar]"/>
	<bone name="NPC L ForearmA [LLar]"/>
