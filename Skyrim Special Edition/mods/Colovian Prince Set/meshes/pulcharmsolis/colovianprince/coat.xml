	<bone name="NPC Spine2 [Spn2]"/>
	
	
	<bone-default name="noMass">
		<mass>0.000</mass>
		<inertia x="1" y="1" z="1"/>
		<linearDamping>0.9</linearDamping>
		<angularDamping>0.9</angularDamping>
		<friction>0.9</friction>
		<restitution>1</restitution>
	</bone-default>
	
	<bone-default name="mass">
		<mass>0.02</mass>
		<inertia x="1" y="1" z="1"/>
		<centerOfMassTransform>
			<basis x="0" y="0" z="0" w="1"/>
			<origin x="0" y="0" z="0"/>
		</centerOfMassTransform>
		<linearDamping>0.8</linearDamping>
		<angularDamping>0.8</angularDamping>
		<friction>0.9</friction>
		<restitution>1</restitution>
	</bone-default>
	
	
	<bone name="CB 01 2" template="mass"/>	
	<bone name="CB 01 3" template="mass"/>
	<bone name="CB 01 4" template="mass"/>
	<bone name="CB 01 5" template="mass"/>
	<bone name="CB 01 6" template="mass"/>

	
	<bone name="CB 02 2" template="mass"/>
